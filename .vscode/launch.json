{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Extension (nolo-helm)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/../nolo-helm/nolo-helm"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: compile"
    },
    {
      "name": "Launch Extension (current folder)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: compile"
    }
  ]
}
