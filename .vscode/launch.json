{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Extension (sample)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["${workspaceFolder}/sample"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: compile"
    },
    {
      "name": "Launch Extension (nolo-helm)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["${workspaceFolder}/../nolo-helm/nolo-helm"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: compile"
    },
    {
      "name": "Launch Extension (current folder)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: compile"
    }
  ]
}
